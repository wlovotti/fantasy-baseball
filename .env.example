# Yahoo Fantasy API Credentials
# Get these from https://developer.yahoo.com/apps/
YAHOO_CLIENT_ID=your_client_id_here
YAHOO_CLIENT_SECRET=your_client_secret_here

# Yahoo League ID (found in your league URL)
YAHOO_LEAGUE_ID=your_league_id_here

# Game key for the current MLB season (e.g., "mlb" or the numeric game key)
YAHOO_GAME_KEY=mlb
